<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/brightdate_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.35"
        android:text="@string/brightdate_label"
        android:textColor="@color/widget_label"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/brightdate_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="sans-serif-black"
        android:text="@string/brightdate_placeholder"
        android:textColor="@color/widget_value"
        android:textSize="32sp"
        android:textStyle="bold" />

</LinearLayout>
